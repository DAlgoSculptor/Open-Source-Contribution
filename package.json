{
  "name": "cluely-clone",
  "productName": "Cluely Clone",
  "version": "1.0.0",
  "description": "Transparent overlay Electron app for live OpenAI answers, hidden from dock and screen sharing.",
  "author": "Raviteja-me",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.cluelyclone.app",
    "productName": "Cluely Clone",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "icon.icns",
      "darkModeSupport": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "This app requires microphone access to capture your voice.",
        "NSCameraUsageDescription": "This app requires screen recording access to capture your screen."
      }
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build-icon.png"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.github/**",
      "!*.md"
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.2.3",
    "electron-builder": "^24.6.0"
  }
}
